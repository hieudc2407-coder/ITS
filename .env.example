# Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=Illegal Parking Detection System
APP_VERSION=1.0.0
DEBUG=False

# API
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=Parking Detection API
API_DESCRIPTION=API for illegal parking detection and notification

# Database
DATABASE_URL=sqlite:///./parking_detection.db
# For PostgreSQL: postgresql://user:password@localhost/parking_db

# JWT/Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Telegram Bot
TELEGRAM_BOT_TOKEN=8571903310:AAHKCPEr8Zb3aiOwYWHFegir_ZEQyppBKb4
TELEGRAM_CHAT_ID=-5136161951
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook
TELEGRAM_USE_WEBHOOK=False

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SENDER_EMAIL=your_email@gmail.com

# AI/Model Configuration
MODEL_PATH=./data/models/
VIDEO_PATH=./data/videos/
IMAGE_PATH=./data/images/
EVIDENCE_PATH=./data/evidence/

# Model Settings
CONFIDENCE_THRESHOLD=0.5
NMS_THRESHOLD=0.4
MODEL_NAME=yolov8

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
